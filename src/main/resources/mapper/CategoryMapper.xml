<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.ssmshop.mapper.CategoryMapper">
    <select id="findEnabled" resultType="Category">
        SELECT * FROM categories WHERE enabled = TRUE ORDER BY sort_order ASC, id ASC
    </select>

    <select id="findAll" resultType="Category">
        SELECT * FROM categories ORDER BY sort_order ASC, id ASC
    </select>

    <select id="findById" resultType="Category">
        SELECT * FROM categories WHERE id = #{id}
    </select>
</mapper>
